#!/usr/bin/env bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_BASE="$HOME/.claude/skills"

mkdir -p "$SKILLS_BASE"

# Symlink the entire repo so skills can reference templates/ and references/
ln -snf "$SCRIPT_DIR" "$SKILLS_BASE/you-got-skills"

# Symlink each skill directly under ~/.claude/skills/ for Claude Code discovery
for skill_dir in "$SCRIPT_DIR"/skills/ygs-*; do
  skill_name="$(basename "$skill_dir")"
  ln -snf "$skill_dir" "$SKILLS_BASE/$skill_name"
done

echo "✓ Installed you-got-skills → $SKILLS_BASE/you-got-skills"
echo "✓ Symlinked $(ls -d "$SCRIPT_DIR"/skills/ygs-* | wc -l | tr -d ' ') skills into $SKILLS_BASE/"
echo ""
echo "Skills available (invoke with /<name>):"
for skill_dir in "$SCRIPT_DIR"/skills/ygs-*; do
  echo "  /$(basename "$skill_dir")"
done
